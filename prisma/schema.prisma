generator client {
  provider = "prisma-client-js"  // Change this from "prisma-client" to "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Appointment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  phone     String
  date      DateTime
  time      String
  createdAt DateTime @default(now())

  @@unique([date, time])
}